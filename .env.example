#-------------⚙️⚙️⚙️BOT CONFIG⚙️⚙️⚙️
# RU: Токен телеграм бота
# EN: Telegram Bot Token
TG_TOKEN=...

# RU: API-ключ Anthropic Claude (для функции "Спросить ИИ")
# EN: Anthropic API key (for the "Ask AI" feature)
ANTHROPIC_API_KEY=...

# RU: Whitelist user_id, кому доступна функция "Спросить ИИ" (через запятую). Пусто = выключено для всех.
# EN: Whitelist of user_ids allowed to use the "Ask AI" feature (comma-separated). Empty = disabled for everyone.
AI_ALLOWED_USER_IDS=

# RU: Главные(системные) администраторы (телеграм id). Список может быть бесконечный, разделяйте запятыми
# EN: Root admins (telegram id). The list can be endless, separate with commas
DEFAULT_ADMINS=...

# RU: Боты для уведомлений в топики / Один бот - максимум 20 регистраций в секунду
# EN: ALERT BOTS FOR TOPICS / One bot - maximum 20 registrations per second
ALERT_BOTS=False

#-------------⛔️⛔️⛔️Системные зависимости | System dependencies⛔️⛔️⛔️
# RU: Настоятельно не рекомендую менять значения, указанные ниже, может привести с ошибкам и нестабильной работе
# EN: I strongly do not recommend changing the values indicated below, it can lead to errors and unstable operation

# DATABASE CONNECTION
MYSQL_HOST=...
MYSQL_PORT=3306
MYSQL_USER=...
MYSQL_PASSWORD=...
MYSQL_DATABASE=...

# SERVER STATES
PROJECT_DEBUG=True
SQL_DEBUG=False
RESET_TEXTS=False

# TROTTLING CONFIG: Events/Updates
THROTTLING_MAX_RATE=5
THROTTLING_PERIOD=1

# ALBUM MIDDLEWARE CONFIG
ALBUM_LATENCY=0.02
ALBUM_AUTO_DELETE=30.0

#-------------🔔🔔🔔 ТРИГГЕРНЫЕ АЛАРМЫ | TRIGGER ALARMS 🔔🔔🔔
# Правила (пороги/тексты/вкл-выкл) задаются в админ-панели (таблица wl_alarm_rules).
# Эти переменные — рубильники безопасности на стороне бота.
#
# RU: Главный выключатель. False = движок и расписание не запускаются вообще.
# EN: Master switch. False = engine & scheduler never start.
ALARMS_ENABLED=False
# RU: Сухой прогон — только логировать, кому что ушло БЫ, ничего не отправлять.
# EN: Dry-run — log who WOULD get what, send nothing. KEEP TRUE UNTIL TESTED.
ALARMS_DRY_RUN=True
# RU: Слать ВСЕ алармы в этот chat_id (себе) вместо реальных получателей. 0 = выкл.
# EN: Route ALL alarms to this chat instead of real recipients. 0 = off.
ALARM_TEST_CHAT_ID=0
# RU: Множитель порогов для тестов. 1 = реальные сроки. ~0.0007 ≈ дни→минуты, часы→секунды*60.
# EN: Threshold multiplier for testing. 1 = real. ~0.0007 ≈ days→minutes.
ALARM_THRESHOLD_SCALE=1
# RU: Период прохода планировщика, сек (по умолчанию 3600 = раз в час).
# EN: Scheduler period in seconds (default 3600 = hourly).
ALARM_INTERVAL_SEC=3600
# RU: Лимит юзеров за один проход (0 = без лимита; удобно для первых тестов).
# EN: Cap audience per pass (0 = no cap; handy for first tests).
ALARM_MAX_USERS=0
# RU: Пауза между юзерами, сек (бережёт rate-limit телеграма).
# EN: Delay between users in seconds (eases Telegram rate-limit).
ALARM_SEND_DELAY=0.05
# RU: Кулдаун повторной отправки. 0 = аларм уходит юзеру ОДИН раз и больше никогда.
#     N = тот же аларм можно повторить тому же юзеру только спустя N дней.
# EN: Re-send cooldown. 0 = once ever (default). N = re-nudge after N days.
ALARM_RESEND_DAYS=0
# RU: Предохранитель — макс. РЕАЛЬНЫХ отправок за один проход, потом проход
#     останавливается. Спасает от случайного потопа. 0 = без лимита (боевой залп).
# EN: Circuit-breaker — max real sends per pass, then it stops. 0 = unlimited.
ALARM_MAX_SENDS_PER_PASS=50